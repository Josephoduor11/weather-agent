cat > .gitignore << 'EOF'
# Environment variables (CRITICAL - contains API keys)
.env
.env.local
.env.*.local

# Python cache files
__pycache__/
*.py[cod]
*.so
.Python

# Virtual environment
venv/
env/
ENV/
.venv/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*

# Logs and databases
*.log
*.sqlite
*.db

# Testing
.pytest_cache/
.coverage

# Distribution
dist/
build/
*.egg-info/
EOF